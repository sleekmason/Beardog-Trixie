# Openbox sxhkdrc
# These are the keybinds used in openbox.
#########################################################

# Reload sxhkd configuration.
mod4 + Escape
	pkill -USR1 -x sxhkd; notify-send --urgency low 'sxhkd configuration reloaded'

# Keybinds.
mod4 + F1
	x-terminal-emulator -T "Keybinds" -e ld-keys

# Dmenu.
mod4 + F3
	xdmenu
        
# Gammy.
mod4 + g
	toggle.gammy
 
# jgmenu.
mod4 + j
	jgmenu_run

# Conky.
mod4 + c
	conky-toggle

# Toggle tint2 panel on/off.
mod4 + w
	toggle.tint2
	
# Toggle tint2 Options.
shift + mod4 + w
	tint2-options
	
# Picom.
mod4 + p
	toggle.picom

# terminal.
mod4 + Return
	x-terminal-emulator

# File Manager.	
mod4 + t
	thunar

# File Manager split view.
shift + mod4 + t
	splitview
	
# File Manager split vertical-horizontal.
mod4 + s
	xfconf-query -c thunar -p /misc-vertical-split-pane -T

# Editor.
mod4 + e
	geany  

# Wallpaper.
mod4 + shift v
	feh-set-wallpaper	

# Random BG.
mod4 + v
	wallpaper-keybind-toggle

# Logout.
mod4 + x
	ld-logout

# Logout alternative.
shift + mod4 + x
	~/.config/rofi/scripts/nakedquit
	
# Hotcorners
mod4 + z
	toggle.ld
	
#Volume Controls
XF86AudioLowerVolume
	 pamixer --decrease 5 && notify-send "Volume down" -u low -t 500 
XF86AudioRaiseVolume
	 pamixer --increase 5 && notify-send "Volume up" -u low -t 500
XF86AudioMute
	 pamixer --toggle-mute && notify-send "Mute/Unmute" -u low -t 2000

#Brightness controls
XF86MonBrightnessDown
	brightnessctl s 10%-

XF86MonBrightnessUp
	brightnessctl s 10%+			

# screenshot and selection capture.
Print
	xfce4-screenshooter

# screenshot and selection capture scrot.
alt + Print
	scrot-options
