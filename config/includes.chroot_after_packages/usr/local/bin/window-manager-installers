#!/bin/bash

yad --title "WM Installers" --escape-ok \
--form --center --width=240 --height=420 --borders=6 \
--text="\nWindow Manager Installers\n" --text-align=center \
--window-icon=applications-utilities \
    --form \
    --field="Awesome WM":FBTN "x-terminal-emulator --title='Awesome WM Installer' -e bash -c "awesome-installer"" \
    --field="DKWM":FBTN "x-terminal-emulator --title='Dk WM Installer' -e bash -c "dk-installer"" \
    --field="DWM":FBTN "x-terminal-emulator --title='DWM Installer' -e bash -c "dwm-installer"" \
    --field="i3 WM":FBTN "x-terminal-emulator --title='i3 WM Installer' -e bash -c "i3wm-installer"" \
    --field="JWM":FBTN "x-terminal-emulator --title='JWM Installer' -e bash -c "jwm-installer"" \
    --field="SOWM":FBTN "x-terminal-emulator --title='SOWM Installer' -e bash -c "sowm-installer"" \
    --field="SOWM Borders":FBTN "x-terminal-emulator --title='SOWM Borders Installer' -e bash -c "sowm-borders-installer"" \
    --field="":LBL "" \
    --field="":LBL "" \
    --field="   Other Installers!/usr/share/icons/gnome/22x22/categories/applications-other.png":FBTN "bash -c 'ld-installers'"
