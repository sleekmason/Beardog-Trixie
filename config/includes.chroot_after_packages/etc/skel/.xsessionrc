### modify session to allow /sbin /usr/sbin ~/bin ~/.local/bin into path 
## during the session.

# Make qt work for luckybackup - others
export QT_QPA_PLATFORMTHEME=gtk2

# include snaps in PATH
if [ -d "/snap/bin" ] ; then
    PATH="${PATH:+${PATH}:}/snap/bin"
fi

# Add directories to $PATH if not added.
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi
if [ -d "/usr/sbin" ] ; then
    PATH="${PATH:+${PATH}:}/usr/sbin"
fi
if [ -d "/sbin" ] ; then
    PATH="${PATH:+${PATH}:}/sbin"
fi

# Disable overlay scrollbars
# export GTK_OVERLAY_SCROLLING=0
