		sed -i 's/^time1_font = .*/time1_font = Noto Sans Bold 8/g' "$FILE"
		sed -i 's/^task_font = .*/task_font = Noto Sans Display 9/g' "$FILE"
		sed -i 's/^taskbar_name_font = .*/taskbar_name_font = Noto Sans 8/g' "$FILE"
