export -f 12
export -f 14
export -f 16
export -f 18
export -f 20
export -f 22
export -f 24
export -f 26

yad --title "Tint2 Size" --escape-ok --borders=14 \
	--geometry=220x292-532-353 --buttons-layout=edge \
	--text="Default = 18\n" --text-align=center \
	--window-icon=tint2-conf \
	--form --columns=2 \
	--field=" 12":FBTN "bash -c 12 >/dev/null 2>&1 &" \
	--field=" 14":FBTN "bash -c 14 >/dev/null 2>&1 &" \
	--field=" 16":FBTN "bash -c 16 >/dev/null 2>&1 &" \
	--field=" 18":FBTN "bash -c 18 >/dev/null 2>&1 &" \
	--field=" 20":FBTN "bash -c 20 >/dev/null 2>&1 &" \
	--field=" 22":FBTN "bash -c 22 >/dev/null 2>&1 &" \
	--field=" 24":FBTN "bash -c 24 >/dev/null 2>&1 &" \
	--field=" 26":FBTN "bash -c 26 >/dev/null 2>&1 &"
